PORT=8080
HOST=0.0.0.0

# file mantiene el prototipo guardando en backend/data/state.json.
# postgres guarda el estado puente en backend_state_snapshots.
STORAGE_DRIVER=file

# Requerido cuando STORAGE_DRIVER=postgres.
DATABASE_URL=postgres://usuario:clave@localhost:5432/sgsta_agent

# Permite tener varios snapshots si se quiere separar demo/dev/prod.
STATE_KEY=default

# IA opcional para que el agente diligencie borradores con DeepSeek.
# La clave debe configurarse solo en el backend/Railway, nunca en app/*.js.
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
